# Microsoft Azure AD Authentication
AZURE_AD_CLIENT_ID=your_client_id_here
AZURE_AD_CLIENT_SECRET=your_client_secret_here
AZURE_AD_TENANT_ID=your_tenant_id_here

# NextAuth Secret (Requerido para encriptar las sesiones)
# Puedes generar uno con: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Obsidian Publish Proxy Config
# La URL base de tu sitio en Obsidian Publish (ej: https://publish.obsidian.md/konexa-docs)
OBSIDIAN_URL=https://publish.obsidian.md/tu-sitio-aqui

# La cookie de autenticación de Obsidian Publish.
# Puedes obtenerla iniciando sesión manualmente en tu sitio de Obsidian y copiando la cookie desde las herramientas de desarrollador del navegador.
OBSIDIAN_AUTH_COOKIE="obsidian-publish-auth=valor_de_la_cookie_aqui"
